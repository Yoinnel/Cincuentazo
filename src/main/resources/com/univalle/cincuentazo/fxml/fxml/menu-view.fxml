<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.univalle.cincuentazo.controller.MainMenuController">
   <VBox alignment="CENTER" layoutX="20.0" layoutY="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
      </padding>
      <Label fx:id="GameTitle" alignment="CENTER" text="CINCUENTAZO" textAlignment="CENTER">
         <font>
            <Font size="96.0" />
         </font>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </Label>
      <Button fx:id="PlayButton" mnemonicParsing="false" onAction="#onPlayButtonClick" text="JUGAR">
         <font>
            <Font size="30.0" />
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Button>
      <Button fx:id="HowToPlayButton" mnemonicParsing="false" onAction="#onHowToPlayButtonClick" text="COMO JUGAR">
         <font>
            <Font size="30.0" />
         </font>
         <VBox.margin>
            <Insets bottom="20.0" />
         </VBox.margin>
      </Button>
   </VBox>
   <VBox alignment="BOTTOM_LEFT" mouseTransparent="true" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <Label fx:id="Credits" text="Creado por: Yoinnel Martinez &amp; Esteban Granada">
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" />
         </VBox.margin>
      </Label>
   </VBox>
</AnchorPane>
