<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.univalle.cincuentazo.controller.HowToPlayController">
   <children>
      <VBox alignment="TOP_CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label text="¿Qué es &quot;Cincuentazo&quot;?">
               <font>
                  <Font size="50.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Label>
            <Label prefWidth="1080.0" text="&quot;Cincuentazo&quot; es un juego de cartas de Poker donde cada jugador debe tirar 1 de sus 4 cartas en la mano central sin que suma de esta exceda el valor de 50." textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" left="100.0" right="100.0" />
               </VBox.margin>
            </Label>
            <Separator prefWidth="200.0" />
            <Label text="¿Cómo jugar?">
               <font>
                  <Font size="50.0" />
               </font>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Label text="El juego se desarrolla por turnos. En su turno, el jugador debe tirar una carta de su mano teniendo en cuenta las siguientes reglas:" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label text="1. → Las cartas con numeros del 2 al 8 y el 10 suman su número." textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label text="2. → Todas las cartas con numero 9 no suman ni restan." textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label text="3. → Todas las cartas con letras J, Q, K restan 10." textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label text="4. → Todas las cartas con letra A suman 1 o 10, según convenga." textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            <Separator prefWidth="200.0" />
            <Label text="¿Cómo ganar?">
               <font>
                  <Font size="50.0" />
               </font>
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Label text="¡Debes sobrevivir y eliminar a los demás jugadores obligandolos a hacer que sus cartas sumen más de 50 a la mano central!" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label text="¡Buena suerte intentando no hacer un CINCUENTAZO!" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="20.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" top="10.0" />
               </VBox.margin>
            </Label>
         </children>
         <padding>
            <Insets top="20.0" />
         </padding>
      </VBox>
      <VBox alignment="BOTTOM_CENTER" prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <Button fx:id="HowToPlayBackButton" alignment="CENTER" mnemonicParsing="false" onAction="#onHowToPlayBackButtonClick" text="Regresar">
            <font>
               <Font size="20.0" />
            </font>
            <VBox.margin>
               <Insets bottom="20.0" />
            </VBox.margin>
         </Button>
      </VBox>
   </children>
</AnchorPane>
